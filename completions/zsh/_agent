#compdef agent
# Completion for the `agent` shortcut (programs/agent.sh).
# Keep the name list in sync with _AGENT_NAMES / _agent_addr there.

_agent() {
    local -a subcommands agents
    subcommands=(
        'ls:list deployed agents and liveness'
        'help:show usage'
    )
    agents=(
        'amy:Amy — studio-1 general-purpose agent'
        'studio-1-steward:Studio 1 host steward — interactive r/w (codex)'
        'observability-steward:Observability service steward — interactive r/w (codex)'
        'coding-steward:Coding pipeline steward — memory Q&A + ingest debug (codex)'
        'hf-data-steward:HF data service steward — interactive r/w (codex)'
        'x-data-steward:X data service steward — interactive r/w (codex)'
        'mini-1-steward:mini-1 host steward — interactive r/w (codex)'
        'mini-2-steward:mini-2 host steward — interactive r/w (codex)'
    )
    _describe -t agents 'agent' agents
    _describe -t subcommands 'subcommand' subcommands
}

_agent "$@"
